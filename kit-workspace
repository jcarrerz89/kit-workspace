  kit-workspace add-project my-app ~/code/my-app
  kit-workspace run ~/.kit-workspace/jobs/my-feature.json --dry-run
  kit-workspace run job-001.json --mode 3
  kit-workspace status job-001
  kit-workspace logs job-001 --role developer --follow

${BOLD}DOCS${NC}
  https://github.com/your-org/kit-workspace

EOF
}

# =============================================================================
# Main dispatcher
# =============================================================================
main() {
  local cmd="${1:-help}"
  shift || true

  case "$cmd" in
    init)            cmd_init "$@" ;;
    add-project)     cmd_add_project "$@" ;;
    list-projects)   cmd_list_projects "$@" ;;
    session)         cmd_session "$@" ;;
    sessions)        cmd_session list "$@" ;;
    add-app)         cmd_add_app "$@" ;;
    list-apps)       cmd_list_apps "$@" ;;
    new)             cmd_new "$@" ;;
    refine)          cmd_refine "$@" ;;
    run)             cmd_run "$@" ;;
    status)          cmd_status "$@" ;;
    dashboard)       cmd_dashboard "$@" ;;
    logs)            cmd_logs "$@" ;;
    merge)           cmd_merge "$@" ;;
    history)         cmd_history "$@" ;;
    stop)            cmd_stop "$@" ;;
    clean)           cmd_clean "$@" ;;
    doctor)          cmd_doctor "$@" ;;
    version|-v|--version) cmd_version ;;
    help|-h|--help)  cmd_help ;;
    *)
      log_error "Unknown command: $cmd"
      echo "Run 'kit-workspace help' for usage."
      exit 1
      ;;
  esac
}

main "$@"

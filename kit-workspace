  echo -e "${BOLD}App groups:${NC}"
  workspace_list_apps
  echo ""
}

# =============================================================================
# Subcommand: session <subcommand> [args...]
# =============================================================================
cmd_session() {
  local sub="${1:-help}"
  shift || true

  case "$sub" in
    start)
      local target="${1:-}"
      local name="${2:-}"
      local description="${3:-}"
      local mode=""

      shift 3 2>/dev/null || true
      while [ $# -gt 0 ]; do
        case "$1" in
          --mode) mode="${2:-}"; shift 2 ;;
          *) shift ;;
        esac
      done

      if [ -z "$target" ] || [ -z "$name" ] || [ -z "$description" ]; then
        log_error "Usage: kit-workspace session start <app-or-project> <name> \"<description>\" [--mode 1|2|3|4]"
        exit 1
      fi

      local job_path
      job_path=$(session_create "$target" "$name" "$description") || exit 1

      if [ -n "$mode" ]; then
        export KWS_MODE="$mode"
      fi
      export DRY_RUN="false"
      meta_run_job "$job_path"
      ;;

    list|ls)
      echo ""
      echo -e "${BOLD}Sessions:${NC}"
      session_list
      echo ""
      ;;

    status)
      local job_id="${1:-}"
      meta_status "$job_id"
      ;;

    merge)
      local job_id="${1:-}"
      if [ -z "$job_id" ]; then
        log_error "Usage: kit-workspace session merge <session-id>"
        exit 1
      fi
      merge_job "$job_id"
      ;;

    stop)
      local job_id="${1:-}"
      if [ -z "$job_id" ]; then
        log_error "Usage: kit-workspace session stop <session-id>"
        exit 1
      fi
      cmd_stop "$job_id"
      ;;

    logs)
      cmd_logs "$@"
      ;;

    help|*)
      cat << EOF

${BOLD}kit-workspace session${NC}

  start <app-or-project> <name> "<description>" [--mode 1|2|3|4]
      Start a new session. Target can be an app group or a single project.
      kit-workspace picks the branch, agents, and driver automatically.
      Mode defaults to headless (3).

  list
      List all sessions with status and inferred type.

  status <session-id>
      Show detailed status for a session.

  merge <session-id>
      Merge the session branch(es) into main and infer session type.

  stop <session-id>
      Stop a running session.

  logs <session-id> [--follow]
      Tail session logs.

EOF
      ;;
  esac
}

